                <field name="rate"/>

                <group expand="0" string="Group By">

                    <filter
                        name="group_by_policy"
                        string="Policy"
                        context="{'group_by': 'policy_id'}"
                    />

                    <filter
                        name="group_by_year"
                        string="Year"
                        context="{'group_by': 'year'}"
                    />

                </group>

            </search>
        </field>
    </record> -->


    <!-- Action -->
    <record id="action_pf_interest_rate" model="ir.actions.act_window">
        <field name="name">PF Interest Rates</field>
        <field name="res_model">pf.interest.rate</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_pf_interest_rate_search"/> -->
    </record>

</odoo>