<odoo>

    <record id="view_company_form_inherit_pf" model="ir.ui.view">
        <field name="name">res.company.form.inherit.pf</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>

        <field name="arch" type="xml">

            <xpath expr="//sheet/group" position="after">

                <group string="PF Configuration">

                    <field name="pf_payable_account_id"/>
                    <field name="pf_bank_account_id"/>

                </group>

            </xpath>

        </field>
    </record>

</odoo>