    <!-- Action -->
    <record id="action_pf_settlement" model="ir.actions.act_window">
        <field name="name">PF Settlements</field>
        <field name="res_model">pf.settlement</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_pf_settlement_search"/> -->
    </record>

</odoo>