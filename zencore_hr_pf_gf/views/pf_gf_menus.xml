<!-- views/pf_menu_views.xml -->

<odoo>

    <!-- Root Menu -->
    <menuitem
        id="menu_zencore_hr_root"
        name="Zencore Hr Benefits Fund"
        sequence="10"
    />


    <!-- Fund Account Menu -->
    <menuitem
        id="menu_fund_account"
        name="Fund Accounts"
        parent="menu_zencore_hr_root"
        sequence="10"
    />


    <!-- PF Account Menu -->
    <menuitem
        id="menu_emp_pf_account"
        name="PF Accounts"
        parent="menu_fund_account"
        action="action_pf_account"
        sequence="10"
    />


    <!-- PF Transaction Menu -->
    <menuitem
        id="menu_pf_transaction"
        name="PF Transactions"
        parent="menu_fund_account"
        action="action_pf_transaction"
        sequence="20"
    />


    <!-- PF Settlement Menu -->
    <menuitem
        id="menu_pf_settlement"
        name="PF Settlements"
        parent="menu_fund_account"
        action="action_pf_settlement"
        sequence="30"
    />


    <!-- Configuration Menu -->
    <menuitem
        id="menu_configuration"
        name="Configuration"
        parent="menu_zencore_hr_root"
        sequence="20"
    />


    <!-- PF Policy Menu -->
    <menuitem
        id="menu_pf_policy"
        name="PF Policies"
        parent="menu_configuration"
        action="action_pf_policy"
        sequence="10"
    />


    <!-- Interest Rate Menu -->
    <menuitem
        id="menu_pf_interest_rate"
        name="PF Interest Rates"
        parent="menu_configuration"
        action="action_pf_interest_rate"
        sequence="20"
    />

</odoo>