<odoo>

    <!-- Tree View -->
    <record id="view_pf_policy_vesting_list" model="ir.ui.view">
        <field name="name">pf.policy.vesting.list</field>
        <field name="model">pf.policy.vesting</field>
        <field name="arch" type="xml">
            <list>
                <field name="policy_id"/>
                <field name="service_year_from"/>
                <field name="service_year_to"/>
                <field name="employer_share_percent"/>
                <field name="active"/>
            </list>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_pf_policy_vesting_form" model="ir.ui.view">
        <field name="name">pf.policy.vesting.form</field>
        <field name="model">pf.policy.vesting</field>
        <field name="arch" type="xml">
            <form string="PF Vesting Rule">

                <sheet>

                    <group>
                        <group>
                            <field name="policy_id"/>
                            <field name="active"/>
                        </group>

                        <group>
                            <field name="service_year_from"/>
                            <field name="service_year_to"/>
                            <field name="employer_share_percent"/>
                        </group>
                    </group>

                </sheet>

            </form>
        </field>
    </record>


    <!-- Action -->
    <record id="action_pf_policy_vesting" model="ir.actions.act_window">
        <field name="name">PF Vesting Rules</field>
        <field name="res_model">pf.policy.vesting</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>