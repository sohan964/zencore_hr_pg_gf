<!-- views/pf_transaction_views.xml -->

<odoo>

    <!-- Tree View -->
    <record id="view_pf_transaction_list" model="ir.ui.view">
        <field name="name">pf.transaction.list</field>
        <field name="model">pf.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="transaction_date"/>
                <field name="pf_account_id"/>
                <field name="employee_id"/>
                <field name="transaction_type"/>
                <field name="amount_employee"/>
                <field name="amount_employer"/>
                <field name="amount_interest"/>
                <field name="total_amount"/>
                <field name="balance_after"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_pf_transaction_form" model="ir.ui.view">
        <field name="name">pf.transaction.form</field>
        <field name="model">pf.transaction</field>
        <field name="arch" type="xml">
            <form string="PF Transaction">

                <header>

                    <button
                        name="action_post"
                        string="Post"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,posted,cancelled"
                    />

                </header>

                <sheet>
                    <widget
                        name="web_ribbon"
                        title="Pending"
                        bg_color="text-bg-warning"
                        invisible="
                            payment_status != 'pending'
                            or state=='draft'
                        "
                    />

                    <widget
                        name="web_ribbon"
                        title="Paid"
                        bg_color="text-bg-success"
                        invisible="
                            payment_status != 'paid'
                            or state=='draft'
                        "
                    />
                    <group>

                        <group>
                            <field name="pf_account_id"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="transaction_type"/>

                            <field
                                name="journal_id"
                                readonly="state == 'posted'"
                            />

                            <field
                                name="debit_account_id"
                                readonly="state == 'posted'"
                            />

                            <field
                                name="credit_account_id"
                                readonly="state == 'posted'"
                            />
                        </group>

                        <group>
                            <field name="transaction_date"/>
                            <field name="payroll_id"/>
                            <field name="move_id" readonly="1"/>
                        </group>

                    </group>

                    <group string="Amounts" col="4">

                        <field name="amount_employee"/>
                        <field name="amount_employer"/>
                        <field name="amount_interest"/>
                        <field name="total_amount" readonly="1"/>

                    </group>

                    <group>

                        <field name="balance_after" readonly="1"/>
                        <field name="remarks"/>

                    </group>

                </sheet>
                <chatter/>

            </form>
        </field>
    </record>


