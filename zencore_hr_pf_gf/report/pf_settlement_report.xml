<odoo>

    <template id="report_pf_settlement_document">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <t t-call="web.external_layout">

                    <div class="page">

                        <!-- Header -->
                        <div class="row mb-4">

                            <div class="col-6">
                                <img
                                    t-if="o.company_id.logo"
                                    t-att-src="image_data_uri(o.company_id.logo)"
                                    style="max-height: 90px;"
                                />
                            </div>

                            <div class="col-6 text-end">

                                <h2>
                                    <span t-field="o.company_id.name"/>
                                </h2>

                                <div>
                                    Provident Fund Settlement Report
                                </div>

                            </div>

                        </div>

                        <hr/>

                        <!-- Employee Information -->
                        <h4 class="mt-3 mb-3">
                            Employee Information
                        </h4>

                        <table class="table table-bordered table-sm">

                            <tr>
                                <td width="35%">
                                    <strong>Employee Name</strong>
                                </td>

                                <td>
                                    <span t-field="o.employee_id"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>PF Account</strong>
                                </td>

                                <td>
                                    <span t-field="o.pf_account_id"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Company</strong>
                                </td>

                                <td>
                                    <span t-field="o.company_id"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Settlement Date</strong>
                                </td>

                                <td>
                                    <span t-field="o.settlement_date"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Separation Date</strong>
                                </td>

                                <td>
                                    <span t-field="o.separation_date"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <strong>Status</strong>
                                </td>

                                <td>
                                    <span t-field="o.state"/>
                                </td>
                            </tr>

                        </table>

                        <!-- Amount Information -->
                        <h4 class="mt-4 mb-3">
                            Settlement Breakdown
                        </h4>

                        <table class="table table-bordered table-sm">

                            <thead>

                                <tr class="table-secondary">

                                    <th>Description</th>
                                    <th class="text-end">Amount</th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr>

                                    <td>Employee Share</td>

                                    <td class="text-end">
                                        <span t-field="o.employee_share"/>
                                    </td>

                                </tr>

                                <tr>

                                    <td>Employer Share</td>

                                    <td class="text-end">
                                        <span t-field="o.employer_share"/>
                                    </td>

                                </tr>

                                <tr>

                                    <td>Vested Share</td>

                                    <td class="text-end">
                                        <span t-field="o.vested_share"/>
                                    </td>

                                </tr>

                                <tr>

                                    <td>Interest Amount</td>

                                    <td class="text-end">
                                        <span t-field="o.interest_amount"/>
                                    </td>

                                </tr>

                                <tr class="table-secondary">

                                    <td>
                                        <strong>Total Payable Amount</strong>
                                    </td>

                                    <td class="text-end">

                                        <strong>
                                            <span t-field="o.payable_amount"/>
                                        </strong>

                                    </td>

                                </tr>

                            </tbody>

                        </table>

                        <!-- Notes -->
                        <div class="mt-5">

                            <strong>Remarks:</strong>

                            <p>
                                This settlement has been generated from the
                                Provident Fund Management System.
                            </p>

                        </div>

                        <!-- Signature -->
                        <div class="row mt-5">

                            <div class="col-6 text-center">

                                <br/><br/><br/>

                                _________________________

                                <div>
                                    Employee Signature
                                </div>

                            </div>

                            <div class="col-6 text-center">

                                <br/><br/><br/>

                                _________________________

                                <div>
                                    Authorized Signature
                                </div>

                            </div>

                        </div>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>