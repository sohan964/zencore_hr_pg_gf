    </record> -->
    <!-- ACTION -->
    <record id="action_profit_sharing_rule" model="ir.actions.act_window">
        <field name="name">Profit Sharing</field>
        <field name="res_model">profit.sharing.rule</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- MENUS -->
    <menuitem
        id="menu_profit_sharing_root"
        name="Profit Sharing"
        parent="hr.menu_human_resources_configuration"
        sequence="90"/>
    <menuitem
        id="menu_profit_sharing_rule"
        name="Profit Sharing Rules"
        parent="menu_profit_sharing_root"
        action="action_profit_sharing_rule"
        sequence="1"/>
</odoo>