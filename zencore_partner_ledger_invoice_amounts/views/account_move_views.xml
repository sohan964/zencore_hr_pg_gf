<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_out_invoice_tree_overdue_red"
            model="ir.ui.view">

        <field name="name">
            account.move.out.invoice.tree.overdue.red
        </field>

        <field name="model">account.move</field>

        <field name="inherit_id"
               ref="account.view_out_invoice_tree"/>

        <field name="arch" type="xml">

            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">invoice_date_due and invoice_date_due &lt; current_date and payment_state != 'paid'</attribute>
            </xpath>

        </field>

    </record>

</odoo>